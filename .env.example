# Supabase — get these from Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side only — get from Dashboard → Settings → API (service_role key)
# Used in API routes to bypass RLS when writing messages / calling Claude
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption key for API key storage (AES-256-GCM).
#  Generated with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-string
# NOTE: Anthropic API keys are stored encrypted in Supabase (users table),
# managed server-side. They are never stored in .env or exposed to the browser.
