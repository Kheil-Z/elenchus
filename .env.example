# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# NOTE: Anthropic API keys are NEVER stored here or on the server.
# They are stored per-user in the browser's localStorage (BYOK architecture).
# Each user's browser calls the Anthropic API directly.
